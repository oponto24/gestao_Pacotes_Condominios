# =====================================================================
# Variáveis de PRODUÇÃO — Sistema de Gestão de Pacotes (story 3.12)
# =====================================================================
# Cópia para .env.prod (NÃO commitado) e preencher secrets.
#
# Uso na VPS:
#   cp .env.prod.example .env.prod
#   nano .env.prod   # preenche valores
#   docker compose -f infra/docker/docker-compose.prod.yml --env-file .env.prod up -d --build
# =====================================================================

# --- Domínio (obrigatório) ---
DOMAIN=app.exemplo.com.br

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=  # gere com: openssl rand -base64 32

# --- Extração de etiqueta (IA) ---
# Provider primário (default: gemini, ~15x mais barato que anthropic).
# Fallback automático em caso de erro 5xx/timeout.
EXTRACT_LABEL_PROVIDER=gemini
EXTRACT_LABEL_FALLBACK=anthropic
EXTRACT_LABEL_MAX_RETRIES=3

# --- Google Gemini (obrigatório se PROVIDER=gemini) ---
# Crie em https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic (obrigatório como fallback) ---
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Clerk (obrigatório) ---
# Pode usar dev keys inicialmente. Promova pra produção quando tiver clientes reais.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=  # opcional; preencher quando configurar webhook em https://<DOMAIN>/api/webhooks/clerk

# --- Meta WhatsApp (Epic 4 — placeholders por enquanto) ---
META_PHONE_NUMBER_ID=placeholder
META_WHATSAPP_TOKEN=placeholder
META_WABA_ID=placeholder
