{
  "name": "gestao-pacotes-condominios",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestão de pacotes em condomínios — PWA + WhatsApp + IA",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "tsx workers/index.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "prisma migrate reset --force",
    "db:apply-rls": "./infra/scripts/apply-rls.sh",
    "db:guard-not-prod": "node -e \"if(process.env.NODE_ENV==='production'){console.error('ABORT: comando destrutivo bloqueado em NODE_ENV=production');process.exit(1)}\"",
    "db:reset-and-seed": "npm run db:guard-not-prod && prisma migrate reset --force && npm run db:apply-rls"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@clerk/nextjs": "^7.3.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@types/papaparse": "^5.5.2",
    "bullmq": "^5.76.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "svix": "^1.92.2",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
