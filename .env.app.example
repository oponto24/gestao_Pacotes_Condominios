# =====================================================================
# .env.app.example — Variáveis da APLICAÇÃO (gestão de pacotes)
# =====================================================================
# Nota: o .env.example da raiz é do framework AIOX. Este arquivo lista
# as variáveis específicas do app, conforme docs/architecture/ARCHITECTURE.md §12.
#
# Copie para .env.local (dev) ou .env.production (prod) e preencha os valores.
# NUNCA commite arquivos com valores reais.
# =====================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (Story 1.3) ---
# IMPORTANTE: hosts são nomes dos services do docker-compose, NÃO localhost.
# - Quando rodando dentro do container: use `postgres` / `redis` (nomes dos services)
# - Quando rodando do host (ex: `psql` direto, `prisma studio`): use `localhost`
#   e as portas mapeadas (5432 / 6379)
DATABASE_URL=postgresql://app:dev_secret@postgres:5432/gestao_pacotes
# Runtime URL — usado pelo APP em runtime (sujeito a RLS, não SUPERUSER).
# A senha é gerada localmente em .env.local e definida via `npm run db:apply-rls`.
DATABASE_RUNTIME_URL=postgresql://app_runtime:CHANGEME@postgres:5432/gestao_pacotes
# Webhook URL — usado pelo handler de webhook Meta (BYPASSRLS pra lookup global).
DATABASE_WEBHOOK_URL=postgresql://webhook_worker:CHANGEME@postgres:5432/gestao_pacotes
# Senhas geradas com: openssl rand -hex 32 (cada uma diferente)
APP_RUNTIME_DB_PASSWORD=
WEBHOOK_WORKER_DB_PASSWORD=

# --- Redis / BullMQ (Story 1.8) ---
REDIS_URL=redis://redis:6379

# --- Clerk (Story 1.5) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SECRET=whsec_

# --- Anthropic (Story 3.5) ---
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_PROMPT_CACHE_ENABLED=true

# --- Meta WhatsApp Cloud API (Story 4.1) ---
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# --- Storage (Story 1.9) ---
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# --- Logs ---
LOG_LEVEL=info

# --- Super-admin (Story 1.10 — seed) ---
SUPER_ADMIN_EMAIL=gustavs.silvs@gmail.com
